# API key for authentication (leave empty to disable auth)
CHURN_API_KEY=

# Server settings
CHURN_API_HOST=0.0.0.0
CHURN_API_PORT=8000
CHURN_LOG_LEVEL=INFO

# CORS allowed origins (comma-separated, e.g. https://myapp.vercel.app,http://localhost:3000)
CHURN_CORS_ORIGINS=["https://churn-clv-api.fly.dev","http://localhost:3000"]
